{
  "manifest_version": 3,
  "name": "NL Browser",
  "version": "1.0.0",
  "description": "Open your personal Nexus Legacy companion dashboard with one click.",
  "browser_specific_settings": {
    "gecko": {
      "id": "nl-browser@sirdimwit",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "permissions": ["cookies"],
  "host_permissions": [
    "https://*.nexuslegacy.space/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "NL Browser",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
